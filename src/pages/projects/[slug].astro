---
// src/pages/projects/[slug].astro
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { join } from 'path';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const profile = JSON.parse(
  readFileSync(join(process.cwd(), 'content/profile.json'), 'utf-8')
);
---

<Base
  profile={profile}
  title={`${project.data.title} — ${profile.name}`}
  description={project.data.description}
>
  <main class="max-w-2xl mx-auto px-6 py-16">
    <a href="/" class="text-sm text-gray-400 hover:text-gray-700 transition-colors mb-8 inline-block">
      ← back
    </a>

    <article>
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-2xl font-bold tracking-tight">{project.data.title}</h1>
          <span class="text-xs px-2 py-0.5 rounded border"
                class:list={[
                  project.data.status === 'active' && 'bg-green-50 text-green-600 border-green-100',
                  project.data.status === 'archived' && 'bg-gray-50 text-gray-400 border-gray-100',
                  project.data.status === 'experiment' && 'bg-blue-50 text-blue-600 border-blue-100',
                ]}>
            {project.data.status}
          </span>
        </div>
        <p class="text-gray-500">{project.data.description}</p>

        <div class="flex gap-4 mt-4 text-sm">
          <a href={project.data.github} target="_blank" rel="noopener noreferrer"
             class="text-gray-500 hover:text-gray-900 transition-colors">
            GitHub ↗
          </a>
          {project.data.url && (
            <a href={project.data.url} target="_blank" rel="noopener noreferrer"
               class="text-gray-500 hover:text-gray-900 transition-colors">
              Live site ↗
            </a>
          )}
        </div>

        <div class="flex flex-wrap gap-1.5 mt-4">
          {project.data.tags.map((tag: string) => (
            <span class="text-xs px-2 py-0.5 rounded bg-gray-50 text-gray-400 border border-gray-100">
              {tag}
            </span>
          ))}
        </div>
      </header>

      {project.data.longDescription && (
        <div class="prose prose-sm prose-gray max-w-none">
          <Content />
        </div>
      )}
    </article>
  </main>
</Base>
