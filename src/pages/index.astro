---
// src/pages/index.astro
// Repo profile page — Cosmic design. Reads state files at build time via fs.

import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import Base from '../layouts/Base.astro';

// Read agent_log.md — parse pipe-delimited entries
let agentLogEntries: Array<{timestamp: string; workflow: string; action: string; outcome: string}> = [];
try {
  const logContent = readFileSync(join(process.cwd(), 'state/agent_log.md'), 'utf-8');
  const lines = logContent
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#') && !l.startsWith('<!--') && l.includes('|'));
  agentLogEntries = lines.map(line => {
    const parts = line.split('|').map(p => p.trim());
    return {
      timestamp: parts[0] || '',
      workflow: parts[1] || '',
      action: parts[2] || '',
      outcome: parts[3] || '',
    };
  });
} catch {}

// Read skill files from skills/ directory
let skills: Array<{name: string; firstLine: string}> = [];
try {
  const skillFiles = readdirSync(join(process.cwd(), 'skills'))
    .filter(f => f.endsWith('.md'))
    .sort();
  skills = skillFiles.map(f => {
    const content = readFileSync(join(process.cwd(), 'skills', f), 'utf-8');
    // Strip YAML frontmatter if present
    let body = content;
    if (body.startsWith('---')) {
      const endIdx = body.indexOf('---', 3);
      if (endIdx !== -1) body = body.slice(endIdx + 3);
    }
    // Extract description from frontmatter
    const fmMatch = content.match(/description:\s*>\s*\n([\s\S]*?)(?=\n\w|\n---)/);
    const fmDesc = fmMatch ? fmMatch[1].replace(/\n\s*/g, ' ').trim() : '';
    // Fallback: first non-heading, non-comment line from body
    const lines = body.split('\n').filter(l => l.trim());
    const descLine = fmDesc || lines.find(l => !l.startsWith('#') && !l.startsWith('<!--') && !l.startsWith('---') && l.trim().length > 10)?.trim() || '';
    return {
      name: f.replace('.md', ''),
      firstLine: descLine.slice(0, 150),
    };
  });
} catch {}

// Read CLAUDE.md failure log entries (lines starting with "# 20" — date-prefixed)
let failureEntries: string[] = [];
try {
  const claudeContent = readFileSync(join(process.cwd(), 'CLAUDE.md'), 'utf-8');
  failureEntries = claudeContent
    .split('\n')
    .filter(l => /^# \d{4}/.test(l))
    .map(l => l.replace(/^# /, ''));
} catch {}

// Read research_log.md
let researchEntries: Array<{timestamp: string; source: string; finding: string}> = [];
try {
  const researchContent = readFileSync(join(process.cwd(), 'state/research_log.md'), 'utf-8');
  const lines = researchContent
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#') && l.includes('|'));
  researchEntries = lines.map(line => {
    const parts = line.split('|').map(p => p.trim());
    return {
      timestamp: parts[0] || '',
      source: parts[1] || '',
      finding: parts[2] || '',
    };
  }).slice(-5);
} catch {}

// Stats
const totalActions = agentLogEntries.length;
const uniqueWorkflows = new Set(agentLogEntries.map(e => e.workflow)).size;
const totalFailures = failureEntries.length;

// Recent activity (last 10)
const recentActivity = agentLogEntries.slice(-10).reverse();
---

<Base>
  <main class="cosmic-main">

    <!-- Hero -->
    <section class="cosmic-section">
      <div class="hero-label">Self-Evolving Scaffold</div>
      <h1 class="hero-title">Agentfolio</h1>
      <p class="hero-subtitle">
        The repo is the system. GitHub Actions workflows triage feedback, fix bugs,
        discover projects, and evolve their own code — daily. Every agent action is a commit.
        The scaffold's first project is itself.
      </p>
    </section>

    <!-- Codex -->
    <section class="cosmic-section">
      <div class="section-header">Codex</div>
      <p class="codex-desc">
        Articles on harness engineering, agent autonomy tiers, self-evolution patterns, and failure handling.
      </p>
      <a href="/codex" class="codex-link">Read the Codex →</a>
    </section>

    <!-- Stats -->
    <section class="cosmic-section">
      <div class="section-header">Stats</div>
      <div class="stats-grid">
        <div class="stat-card stat-purple">
          <div class="stat-value">{totalActions}</div>
          <div class="stat-label">agent actions</div>
        </div>
        <div class="stat-card stat-blue">
          <div class="stat-value">{uniqueWorkflows}</div>
          <div class="stat-label">active workflows</div>
        </div>
        <div class="stat-card stat-green">
          <div class="stat-value">{totalFailures}</div>
          <div class="stat-label">failures prevented</div>
        </div>
      </div>
    </section>

    <!-- Recent Activity -->
    {recentActivity.length > 0 && (
      <section class="cosmic-section">
        <div class="section-header">Recent Activity</div>
        <div>
          {recentActivity.map(entry => (
            <div class="activity-item">
              <time class="activity-time" datetime={entry.timestamp}>
                {entry.timestamp ? new Date(entry.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : ''}
              </time>
              <span class="activity-badge">{entry.workflow}</span>
              <span class="activity-text">{entry.action}</span>
              {entry.outcome && (
                <span class="activity-outcome">{entry.outcome}</span>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Capabilities -->
    {skills.length > 0 && (
      <section class="cosmic-section">
        <div class="section-header">Capabilities</div>
        <div>
          {skills.map(skill => (
            <div class="capability">
              <div class="capability-name">{skill.name}</div>
              {skill.firstLine && (
                <p class="capability-desc">{skill.firstLine}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Research -->
    {researchEntries.length > 0 && (
      <section class="cosmic-section">
        <div class="section-header">Recent Research</div>
        <div>
          {researchEntries.map(entry => (
            <div class="research-item">
              <span class="research-badge">{entry.source}</span>
              <span class="research-text">{entry.finding}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Failure Log -->
    {failureEntries.length > 0 && (
      <section class="cosmic-section">
        <div class="section-header">Mistakes It Won't Make Again</div>
        <div class="failure-list">
          {failureEntries.map(entry => (
            <p class="failure-entry">{entry}</p>
          ))}
        </div>
      </section>
    )}

    <!-- Getting Started -->
    <section class="cosmic-section">
      <div class="section-header">Getting Started</div>
      <ol class="steps">
        <li>Fork this repo</li>
        <li>Add <code>CLAUDE_CODE_OAUTH_TOKEN</code> to your repo secrets</li>
        <li>Enable GitHub Pages (Source: GitHub Actions)</li>
        <li>Drop your project in <code>apps/your-project/</code></li>
        <li>Run the "Discover Project" workflow</li>
      </ol>
      <a href="https://github.com/verkyyi/agentfolio" target="_blank" rel="noopener noreferrer" class="cta-link">
        View on GitHub →
      </a>
      <a href="https://github.com/verkyyi/agentfolio/issues/new" target="_blank" rel="noopener noreferrer" class="cta-link">
        Submit Feedback →
      </a>
    </section>

  </main>
</Base>

<style>
  .cosmic-main {
    max-width: 640px;
    margin: 0 auto;
    padding: 64px 24px;
    position: relative;
  }
  .cosmic-section { margin-bottom: 56px; }

  /* Hero */
  .hero-label {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #a78bfa;
    margin-bottom: 12px;
  }
  .hero-title {
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -1px;
    background: linear-gradient(135deg, #c084fc, #60a5fa, #34d399);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
  }
  .hero-subtitle {
    font-size: 14px;
    color: #94a3b8;
    line-height: 1.6;
    max-width: 480px;
  }

  /* Section headers */
  .section-header {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #7c3aed;
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(124,58,237,0.2);
  }

  /* Stats */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .stat-card {
    border-radius: 12px;
    padding: 20px;
    text-align: center;
    transition: border-color 0.3s, background 0.3s;
  }
  .stat-card:hover { background: rgba(139,92,246,0.12); }
  .stat-purple {
    background: rgba(139,92,246,0.08);
    border: 1px solid rgba(139,92,246,0.15);
  }
  .stat-purple .stat-value { color: #c084fc; }
  .stat-blue {
    background: rgba(96,165,250,0.08);
    border: 1px solid rgba(96,165,250,0.15);
  }
  .stat-blue .stat-value { color: #60a5fa; }
  .stat-green {
    background: rgba(52,211,153,0.08);
    border: 1px solid rgba(52,211,153,0.15);
  }
  .stat-green .stat-value { color: #34d399; }
  .stat-value { font-size: 28px; font-weight: 800; }
  .stat-label { font-size: 11px; color: #64748b; margin-top: 4px; letter-spacing: 0.5px; }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .stat-card { padding: 16px; }
  }

  /* Activity feed */
  .activity-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(139,92,246,0.08);
    font-size: 13px;
  }
  .activity-item:last-child { border-bottom: none; }
  .activity-time {
    color: #475569;
    font-size: 11px;
    width: 52px;
    flex-shrink: 0;
    padding-top: 2px;
  }
  .activity-badge {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(139,92,246,0.15);
    color: #a78bfa;
    border: 1px solid rgba(139,92,246,0.25);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .activity-text { color: #cbd5e1; }
  .activity-outcome { color: #475569; font-size: 11px; margin-left: auto; flex-shrink: 0; }

  /* Capabilities */
  .capability {
    padding: 14px 0;
    border-bottom: 1px solid rgba(139,92,246,0.08);
  }
  .capability:last-child { border-bottom: none; }
  .capability-name {
    font-weight: 600;
    font-size: 14px;
    color: #e2e8f0;
    margin-bottom: 4px;
  }
  .capability-desc {
    font-size: 12px;
    color: #64748b;
    line-height: 1.5;
  }

  /* Research */
  .research-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(59,130,246,0.08);
    font-size: 13px;
  }
  .research-item:last-child { border-bottom: none; }
  .research-badge {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(59,130,246,0.12);
    color: #60a5fa;
    border: 1px solid rgba(59,130,246,0.25);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .research-text { color: #94a3b8; }

  /* Failure log */
  .failure-list {
    padding-left: 12px;
    border-left: 2px solid rgba(239,68,68,0.3);
  }
  .failure-entry {
    font-size: 13px;
    color: #94a3b8;
    padding: 6px 0;
  }

  /* Getting started */
  .steps {
    list-style: none;
    counter-reset: step;
    padding: 0;
  }
  .steps li {
    counter-increment: step;
    padding: 8px 0 8px 32px;
    position: relative;
    font-size: 14px;
    color: #94a3b8;
    line-height: 1.5;
  }
  .steps li::before {
    content: counter(step);
    position: absolute;
    left: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(139,92,246,0.15);
    border: 1px solid rgba(139,92,246,0.3);
    color: #a78bfa;
    font-size: 11px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    top: 9px;
  }
  .steps code {
    font-size: 12px;
    background: rgba(139,92,246,0.1);
    border: 1px solid rgba(139,92,246,0.2);
    padding: 1px 6px;
    border-radius: 4px;
    color: #c084fc;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }
  /* Codex */
  .codex-desc {
    font-size: 14px;
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 12px;
  }
  .codex-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #a78bfa;
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
  .codex-link:hover { color: #c084fc; }

  /* Getting started */
  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 16px;
    color: #a78bfa;
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }
  .cta-link:hover { color: #c084fc; }
</style>
