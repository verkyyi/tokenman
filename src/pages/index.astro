---
// src/pages/index.astro
// Repo profile page — reads state files at build time via fs.

import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';
import Base from '../layouts/Base.astro';

// Read agent_log.md — parse pipe-delimited entries
let agentLogEntries: Array<{timestamp: string; workflow: string; action: string; outcome: string}> = [];
try {
  const logContent = readFileSync(join(process.cwd(), 'state/agent_log.md'), 'utf-8');
  const lines = logContent
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#') && !l.startsWith('<!--') && l.includes('|'));
  agentLogEntries = lines.map(line => {
    const parts = line.split('|').map(p => p.trim());
    return {
      timestamp: parts[0] || '',
      workflow: parts[1] || '',
      action: parts[2] || '',
      outcome: parts[3] || '',
    };
  });
} catch {}

// Read skill files from skills/ directory
let skills: Array<{name: string; firstLine: string}> = [];
try {
  const skillFiles = readdirSync(join(process.cwd(), 'skills'))
    .filter(f => f.endsWith('.md'))
    .sort();
  skills = skillFiles.map(f => {
    const content = readFileSync(join(process.cwd(), 'skills', f), 'utf-8');
    const lines = content.split('\n').filter(l => l.trim());
    // Extract first non-comment, non-heading meaningful line as description
    const descLine = lines.find(l => !l.startsWith('#') && !l.startsWith('<!--') && l.trim().length > 10) || '';
    return {
      name: f.replace('.md', ''),
      firstLine: descLine.trim().slice(0, 120),
    };
  });
} catch {}

// Read CLAUDE.md failure log entries (lines starting with "# 20" — date-prefixed)
let failureEntries: string[] = [];
try {
  const claudeContent = readFileSync(join(process.cwd(), 'CLAUDE.md'), 'utf-8');
  failureEntries = claudeContent
    .split('\n')
    .filter(l => /^# \d{4}/.test(l))
    .map(l => l.replace(/^# /, ''));
} catch {}

// Read research_log.md
let researchEntries: Array<{timestamp: string; source: string; finding: string}> = [];
try {
  const researchContent = readFileSync(join(process.cwd(), 'state/research_log.md'), 'utf-8');
  const lines = researchContent
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#') && l.includes('|'));
  researchEntries = lines.map(line => {
    const parts = line.split('|').map(p => p.trim());
    return {
      timestamp: parts[0] || '',
      source: parts[1] || '',
      finding: parts[2] || '',
    };
  }).slice(-5);
} catch {}

// Stats
const totalActions = agentLogEntries.length;
const uniqueWorkflows = new Set(agentLogEntries.map(e => e.workflow)).size;
const totalFailures = failureEntries.length;

// Recent activity (last 10)
const recentActivity = agentLogEntries.slice(-10).reverse();
---

<Base>
  <main class="max-w-2xl mx-auto px-6 py-16">

    <!-- Hero -->
    <section class="mb-14">
      <h1 class="text-3xl font-bold tracking-tight mb-2">Agentfolio</h1>
      <p class="text-gray-500 text-sm mb-4">A self-evolving scaffold for autonomous web projects</p>
      <p class="text-gray-600 leading-relaxed">
        The repo is the system. GitHub Actions workflows triage feedback, fix bugs,
        discover projects, and evolve their own code — daily. Every agent action is a commit.
        The scaffold's first project is itself.
      </p>
    </section>

    <!-- Stats -->
    <section class="mb-14">
      <h2 class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-5">
        Stats
      </h2>
      <div class="grid grid-cols-3 gap-4">
        <div class="text-center p-4 rounded-lg bg-gray-50 border border-gray-100">
          <div class="text-2xl font-bold text-gray-900">{totalActions}</div>
          <div class="text-xs text-gray-500 mt-1">agent actions</div>
        </div>
        <div class="text-center p-4 rounded-lg bg-gray-50 border border-gray-100">
          <div class="text-2xl font-bold text-gray-900">{uniqueWorkflows}</div>
          <div class="text-xs text-gray-500 mt-1">active workflows</div>
        </div>
        <div class="text-center p-4 rounded-lg bg-gray-50 border border-gray-100">
          <div class="text-2xl font-bold text-gray-900">{totalFailures}</div>
          <div class="text-xs text-gray-500 mt-1">failures prevented</div>
        </div>
      </div>
    </section>

    <!-- Recent Activity -->
    {recentActivity.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-5">
          Recent Activity
        </h2>
        <div class="space-y-2">
          {recentActivity.map(entry => (
            <div class="flex items-start gap-3 text-sm">
              <time class="text-xs text-gray-400 shrink-0 pt-0.5 w-16" datetime={entry.timestamp}>
                {entry.timestamp ? new Date(entry.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : ''}
              </time>
              <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-50 text-gray-500 border border-gray-100 shrink-0">
                {entry.workflow}
              </span>
              <span class="text-gray-600">{entry.action}</span>
              {entry.outcome && (
                <span class="text-gray-400 text-xs ml-auto shrink-0">{entry.outcome}</span>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Capabilities -->
    {skills.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-5">
          Capabilities
        </h2>
        <div class="space-y-3">
          {skills.map(skill => (
            <div class="group">
              <div class="flex items-center gap-2 mb-0.5">
                <span class="font-medium text-sm text-gray-900">{skill.name}</span>
              </div>
              {skill.firstLine && (
                <p class="text-xs text-gray-500 leading-relaxed">{skill.firstLine}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Research -->
    {researchEntries.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-5">
          Recent Research
        </h2>
        <div class="space-y-2">
          {researchEntries.map(entry => (
            <div class="flex items-start gap-3 text-sm">
              <span class="text-[10px] px-1.5 py-0.5 rounded bg-blue-50 text-blue-500 border border-blue-100 shrink-0">
                {entry.source}
              </span>
              <span class="text-gray-600">{entry.finding}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Failure Log -->
    {failureEntries.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-5">
          Mistakes It Won't Make Again
        </h2>
        <div class="space-y-2 pl-3 border-l-2 border-red-100">
          {failureEntries.map(entry => (
            <p class="text-sm text-gray-600">{entry}</p>
          ))}
        </div>
      </section>
    )}

    <!-- Getting Started -->
    <section>
      <h2 class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-5">
        Getting Started
      </h2>
      <div class="space-y-3 text-sm text-gray-600">
        <ol class="list-decimal list-inside space-y-1.5">
          <li>Fork this repo</li>
          <li>Add <code class="text-xs bg-gray-50 px-1 py-0.5 rounded">CLAUDE_CODE_OAUTH_TOKEN</code> to your repo secrets</li>
          <li>Enable GitHub Pages (Source: GitHub Actions)</li>
          <li>Drop your project in <code class="text-xs bg-gray-50 px-1 py-0.5 rounded">apps/your-project/</code></li>
          <li>Run the "Discover Project" workflow</li>
        </ol>
        <div class="flex gap-4 mt-4">
          <a href="https://github.com/verkyyi/agentfolio"
             target="_blank" rel="noopener noreferrer"
             class="text-gray-600 hover:text-gray-900 transition-colors underline underline-offset-2">
            View on GitHub →
          </a>
        </div>
      </div>
    </section>

  </main>
</Base>
