---
// src/layouts/Base.astro
// Reads state/agent_log.md at BUILD TIME for the agent badge.
// This is build-time static injection (Decision 4A).

import { readFileSync } from 'fs';
import { join } from 'path';

interface Props {
  title?: string;
  description?: string;
  profile?: any;
}

const { title, description, profile } = Astro.props;

// Read agent_log.md at build time to extract last action timestamp
let lastAgentAction = '';
let lastAgentTimestamp = '';
try {
  const logPath = join(process.cwd(), 'state/agent_log.md');
  const logContent = readFileSync(logPath, 'utf-8');
  // Find last non-empty, non-comment line
  const lines = logContent
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#') && !l.startsWith('<!--') && l.includes('|'));
  if (lines.length > 0) {
    const lastLine = lines[lines.length - 1];
    const parts = lastLine.split('|').map(p => p.trim());
    lastAgentTimestamp = parts[0] || '';
    const workflow = parts[1] || '';
    const action = parts[2] || '';
    lastAgentAction = `${workflow}: ${action}`;
  }
} catch {
  // state/agent_log.md not yet populated — that's fine on first build
}

// Read profile for meta tags
let profileData = profile;
if (!profileData) {
  try {
    const profilePath = join(process.cwd(), 'content/profile.json');
    profileData = JSON.parse(readFileSync(profilePath, 'utf-8'));
  } catch {}
}

const pageTitle = title || profileData?.name || 'Agentfolio';
const pageDescription = description || profileData?.bio || 'A living portfolio maintained by an AI agent.';
const siteUrl = profileData?.site_url || '';
const canonicalUrl = siteUrl ? `${siteUrl}${Astro.url.pathname}` : '';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  {siteUrl && <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />}

  <!-- JSON-LD Person schema — maintained by agent -->
  {profileData && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": profileData.name,
      "url": siteUrl,
      "description": profileData.bio,
      "sameAs": [
        profileData.github,
        profileData.blog
      ].filter(Boolean),
      "knowsAbout": profileData.skills || [],
    })} />
  )}

  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <slot />

  <!-- Agent badge — timestamp injected at BUILD TIME from state/agent_log.md -->
  {lastAgentTimestamp && (
    <div class="agent-badge" aria-label="This profile is maintained by an AI agent">
      <span class="agent-dot" />
      <span>
        maintained by agent ·
        <a
          href={`${profileData?.github}/${profileData?.username ? `${profileData.username}/agentfolio` : 'agentfolio'}/commits/main`}
          target="_blank"
          rel="noopener noreferrer"
          class="agent-link"
        >
          last update {new Date(lastAgentTimestamp).toLocaleDateString('en-US', {
            month: 'short', day: 'numeric'
          })}
        </a>
      </span>
    </div>
  )}
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: system-ui, sans-serif; background: #fff; color: #111; }

  .agent-badge {
    position: fixed;
    bottom: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #666;
    background: rgba(255,255,255,0.92);
    border: 1px solid #e0e0e0;
    border-radius: 20px;
    padding: 5px 12px;
    backdrop-filter: blur(8px);
    z-index: 50;
  }

  .agent-dot {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .agent-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
