---
import { readFileSync } from 'fs';
import { join } from 'path';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Agentfolio — Self-Evolving Scaffold', description = 'A self-evolving scaffold for autonomous web projects' } = Astro.props;

// Read agent_log.md at build time for agent badge
let lastAgentTimestamp = '';
let lastAgentAction = '';
try {
  const logPath = join(process.cwd(), 'state/agent_log.md');
  const logContent = readFileSync(logPath, 'utf-8');
  const lines = logContent
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#') && !l.startsWith('<!--') && l.includes('|'));
  if (lines.length > 0) {
    const lastLine = lines[lines.length - 1];
    const parts = lastLine.split('|').map(p => p.trim());
    lastAgentTimestamp = parts[0] || '';
    const workflow = parts[1] || '';
    const action = parts[2] || '';
    lastAgentAction = `${workflow}: ${action}`;
  }
} catch {}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:site_name" content="Agentfolio" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="generator" content={Astro.generator} />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <slot />

  {lastAgentTimestamp && (
    <div class="agent-badge" aria-label="This site is maintained by an AI agent">
      <span class="agent-dot" />
      <span>
        maintained by agent ·
        <a href="https://github.com/verkyyi/agentfolio/commits/main" target="_blank" rel="noopener noreferrer" class="agent-link">
          last update {(() => {
            const now = new Date();
            const then = new Date(lastAgentTimestamp);
            const diffMs = now.getTime() - then.getTime();
            const diffMins = Math.floor(diffMs / 60000);
            const diffHours = Math.floor(diffMs / 3600000);
            const diffDays = Math.floor(diffMs / 86400000);
            if (diffMins < 1) return 'just now';
            if (diffMins < 60) return `${diffMins}m ago`;
            if (diffHours < 24) return `${diffHours}h ago`;
            if (diffDays === 1) return 'yesterday';
            if (diffDays < 7) return `${diffDays}d ago`;
            return then.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          })()}
        </a>
      </span>
    </div>
  )}
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html {
    overflow-x: hidden;
  }
  body {
    font-family: system-ui, -apple-system, sans-serif;
    background: #0f0c29;
    background: linear-gradient(160deg, #0f0c29 0%, #1a1145 30%, #1e1b4b 60%, #0f172a 100%);
    color: #e2e8f0;
    min-height: 100vh;
    overflow-x: hidden;
    width: 100%;
  }
  body::before {
    content: '';
    position: fixed;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(139,92,246,0.12), transparent 70%);
    pointer-events: none;
  }
  body::after {
    content: '';
    position: fixed;
    bottom: -100px;
    left: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(59,130,246,0.08), transparent 70%);
    pointer-events: none;
  }

  .agent-badge {
    position: fixed;
    bottom: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #94a3b8;
    background: rgba(15,12,41,0.9);
    border: 1px solid rgba(139,92,246,0.2);
    border-radius: 20px;
    padding: 6px 14px;
    backdrop-filter: blur(12px);
    z-index: 50;
  }

  .agent-dot {
    width: 6px;
    height: 6px;
    background: #34d399;
    border-radius: 50%;
    animation: pulse 2s infinite;
    box-shadow: 0 0 8px rgba(52,211,153,0.4);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .agent-link {
    color: #a78bfa;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
