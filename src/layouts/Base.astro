---
import { readFileSync } from 'fs';
import { join } from 'path';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Agentfolio — Self-Evolving Scaffold', description = 'A self-evolving scaffold for autonomous web projects' } = Astro.props;

// Read agent_log.md at build time for agent badge
let lastAgentTimestamp = '';
let lastAgentAction = '';
try {
  const logPath = join(process.cwd(), 'state/agent_log.md');
  const logContent = readFileSync(logPath, 'utf-8');
  const lines = logContent
    .split('\n')
    .filter(l => l.trim() && !l.startsWith('#') && !l.startsWith('<!--') && l.includes('|'));
  if (lines.length > 0) {
    const lastLine = lines[lines.length - 1];
    const parts = lastLine.split('|').map(p => p.trim());
    lastAgentTimestamp = parts[0] || '';
    const workflow = parts[1] || '';
    const action = parts[2] || '';
    lastAgentAction = `${workflow}: ${action}`;
  }
} catch {}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <slot />

  {lastAgentTimestamp && (
    <div class="agent-badge" aria-label="This site is maintained by an AI agent">
      <span class="agent-dot" />
      <span>
        maintained by agent ·
        <a href="https://github.com/verkyyi/agentfolio/commits/main" target="_blank" rel="noopener noreferrer" class="agent-link">
          last update {new Date(lastAgentTimestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
        </a>
      </span>
    </div>
  )}
</body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: system-ui, sans-serif; background: #fff; color: #111; }

  .agent-badge {
    position: fixed;
    bottom: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: #666;
    background: rgba(255,255,255,0.92);
    border: 1px solid #e0e0e0;
    border-radius: 20px;
    padding: 5px 12px;
    backdrop-filter: blur(8px);
    z-index: 50;
  }

  .agent-dot {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .agent-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
